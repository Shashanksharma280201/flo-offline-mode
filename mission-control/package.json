{
  "name": "mission-control",
  "version": "1.0.0",
  "description": "A mission control stack for Flo Mobility",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "rimraf ./build && npx tsc",
    "preserve": "pnpm run build",
    "serve": "cross-env NODE_ENV=development nodemon",
    "prestart": "pnpm run build",
    "start": "cross-env node --experimental-modules --es-module-specifier-resolution=node  build/server.js",
    "lint": " eslint . --ext .js,.ts",
    "prettier-format": "prettier --config .prettierrc.json --write backend/**/*.ts",
    "format": "pnpm run lint && pnpm run prettier-format",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky install",
    "lint-staged": "npx tsc --noEmit && lint-staged",
    "seed:inventory": "tsx backend/scripts/seedInventory.ts"
  },
  "lint-staged": {
    "backend/**/*.{js,ts}": [
      "eslint",
      "prettier --config .prettierrc.json --write"
    ]
  },
  "author": "Akhilesh B Kalnoor",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-iot": "^3.749.0",
    "@aws-sdk/client-s3": "^3.388.0",
    "@aws-sdk/s3-request-presigner": "^3.388.0",
    "@azure/identity": "^4.7.0",
    "@azure/storage-blob": "^12.26.0",
    "@react-email/components": "^0.0.21",
    "@types/body-parser": "^1.19.2",
    "@types/express": "^4.17.13",
    "@types/morgan": "^1.9.3",
    "aws-iot-device-sdk-v2": "^1.21.1",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.0",
    "bullmq": "^5.8.3",
    "colors": "^1.4.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.10",
    "dotenv": "^16.0.2",
    "express": "^4.18.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.2.1",
    "fast-safe-stringify": "^2.1.1",
    "firebase-admin": "^12.1.0",
    "helmet": "^6.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.29.4",
    "mongodb": "^6.7.0",
    "mongoose": "^6.6.4",
    "morgan": "^1.10.0",
    "multer": "1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.14",
    "nodemon": "^2.0.19",
    "openai": "^4.93.0",
    "rate-limit-redis": "^4.3.0",
    "react": "^18.3.1",
    "redis": "^4.5.0",
    "rimraf": "^3.0.2",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.12",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/multer": "^1.4.7",
    "@types/multer-s3": "^3.0.0",
    "@types/node": "^18.7.16",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sanitize-html": "^2.16.0",
    "@types/uuid": "^9.0.2",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "concurrently": "^7.4.0",
    "eslint": "8.2.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-standard-with-typescript": "^23.0.0",
    "eslint-import-resolver-typescript": "^3.5.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.0.0",
    "husky": "^8.0.0",
    "install-peers": "^1.0.4",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "tsx": "^4.11.0",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^5.0.10"
  }
}
