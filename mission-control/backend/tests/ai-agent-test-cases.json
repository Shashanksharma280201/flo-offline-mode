    {
      "name": "Entity Disambiguation",
      "description": "Test AI's ability to distinguish between clients, operators, and robots",
      "tests": [
        {
          "id": "DIS-1",
          "query": "list all sites",
          "expectedFunctions": ["listClients"],
          "expectedNavigation": null,
          "expectedResponse": "Should call CLIENT functions (sites = physical locations)"
        },
        {
          "id": "DIS-2",
          "query": "list all workers",
          "expectedFunctions": ["listOperators"],
          "expectedNavigation": null,
          "expectedResponse": "Should call OPERATOR functions (workers = people)"
        },
        {
          "id": "DIS-3",
          "query": "list all machines",
          "expectedFunctions": ["listRobots"],
          "expectedNavigation": null,
          "expectedResponse": "Should call ROBOT functions (machines = robots)"
        }
      ]
    },
    {
      "name": "Complex Multi-Function Queries",
      "description": "Test AI handling of queries requiring multiple function calls",
      "tests": [
        {
          "id": "MF-1",
          "query": "show me robot 31 details",
          "expectedFunctions": ["searchRobots", "getRobotDetails", "navigateToPage"],
          "expectedNavigation": "/robots/:id",
          "expectedResponse": "Search robot, get details, and navigate to robot page"
        },
        {
          "id": "MF-2",
          "query": "show operators at client ABC",
          "expectedFunctions": ["searchClients", "getClientDetails", "navigateToPage"],
          "expectedNavigation": null,
          "expectedResponse": "Search client, get details (includes operators), optionally navigate"
        }
      ]
    }
