{
  "testSuites": [
    {
      "name": "Operator Queries",
      "description": "Test AI understanding of operator-related queries",
      "tests": [
        {
          "id": "OP-1",
          "query": "list all operators",
          "expectedFunctions": ["listOperators"],
          "expectedNavigation": null,
          "expectedResponse": "List of all operators with names and phone numbers"
        },
        {
          "id": "OP-2",
          "query": "show operators",
          "expectedFunctions": ["listOperators", "navigateToPage"],
          "expectedNavigation": "/operators",
          "expectedResponse": "List operators and navigate to operators page"
        },
        {
          "id": "OP-3",
          "query": "show operator details",
          "expectedFunctions": ["searchOperators", "getOperatorDetails"],
          "expectedNavigation": null,
          "expectedResponse": "Search for operator and get their details"
        },
        {
          "id": "OP-4",
          "query": "which robots is operator John using",
          "expectedFunctions": ["searchOperators", "getOperatorDetails"],
          "expectedNavigation": null,
          "expectedResponse": "Search for John and return assigned robots"
        }
      ]
    },
    {
      "name": "Client/Site Queries",
      "description": "Test AI understanding of client-related queries",
      "tests": [
        {
          "id": "CL-1",
          "query": "list all clients",
          "expectedFunctions": ["listClients"],
          "expectedNavigation": null,
          "expectedResponse": "List of all client sites"
        },
        {
          "id": "CL-2",
          "query": "list all active clients",
          "expectedFunctions": ["listClients"],
          "expectedParameters": {"isActive": true},
          "expectedNavigation": null,
          "expectedResponse": "List only active client sites"
        },
        {
          "id": "CL-3",
          "query": "show clients",
          "expectedFunctions": ["listClients", "navigateToPage"],
          "expectedNavigation": "/clients",
          "expectedResponse": "List clients and navigate to clients page"
        },
        {
          "id": "CL-4",
          "query": "operators at client ABC",
          "expectedFunctions": ["searchClients", "getClientDetails"],
          "expectedNavigation": null,
          "expectedResponse": "Search for client ABC and return operators assigned to it"
        }
      ]
    },
    {
      "name": "Robot Queries",
      "description": "Test AI understanding of robot-related queries with name variations",
      "tests": [
        {
          "id": "RO-1",
          "query": "list all robots",
          "expectedFunctions": ["listRobots"],
          "expectedNavigation": null,
          "expectedResponse": "List of all robots"
        },
        {
          "id": "RO-2",
          "query": "list idle robots",
          "expectedFunctions": ["listRobots"],
          "expectedParameters": {"status": "idle"},
          "expectedNavigation": null,
          "expectedResponse": "List robots with idle status"
        },
        {
          "id": "RO-3",
          "query": "show robot MMR-31",
          "expectedFunctions": ["searchRobots", "getRobotDetails", "navigateToPage"],
          "expectedNavigation": "/robots/:id",
          "expectedResponse": "Search for MMR-31, get details, and navigate to robot page"
        },
        {
          "id": "RO-4",
          "query": "show robot 31",
          "expectedFunctions": ["searchRobots", "getRobotDetails"],
          "expectedNavigation": null,
          "expectedResponse": "Smart search for robot 31 (normalizes to MMR-31)"
        },
        {
          "id": "RO-5",
          "query": "get details of robot MMR 31",
          "expectedFunctions": ["searchRobots", "getRobotDetails"],
          "expectedNavigation": null,
          "expectedResponse": "Smart search for MMR 31 (normalizes to MMR-31)"
        },
        {
          "id": "RO-6",
          "query": "what is the status of robot 31",
          "expectedFunctions": ["searchRobots", "getRobotDetails"],
          "expectedNavigation": null,
          "expectedResponse": "Get robot details including status"
        }
      ]
    },
    {
      "name": "Mission Execution",
      "description": "Test AI understanding of mission commands with smart matching",
      "tests": [
        {
          "id": "MI-1",
          "query": "send MMR-31 to the kitchen in the office",
          "expectedFunctions": ["executeRobotMission"],
          "expectedParameters": {
            "robotId": "MMR-31",
            "pathMapName": "office",
            "missionName": "kitchen"
          },
          "expectedNavigation": null,
          "expectedResponse": "Execute mission with smart normalization for all three parameters"
        },
        {
          "id": "MI-2",
          "query": "send robot 31 to kitchen in office 1",
          "expectedFunctions": ["executeRobotMission"],
          "expectedParameters": {
            "robotId": "robot 31",
            "pathMapName": "office 1",
            "missionName": "kitchen"
          },
          "expectedNavigation": null,
          "expectedResponse": "Smart normalization: robot 31→MMR-31, office 1→office-1"
        },
        {
          "id": "MI-3",
          "query": "abort mission on robot 31",
          "expectedFunctions": ["abortRobotMission"],
          "expectedParameters": {
            "robotId": "robot 31"
          },
          "expectedNavigation": null,
          "expectedResponse": "Abort mission with smart robot search"
        },
        {
          "id": "MI-4",
          "query": "list available missions",
          "expectedFunctions": ["listPathMaps"],
          "expectedNavigation": null,
          "expectedResponse": "List all pathmaps with their missions"
        }
      ]
    },
