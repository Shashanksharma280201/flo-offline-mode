    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.11.0",
    "vitest": "^4.0.18",
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.21"
  }
}
