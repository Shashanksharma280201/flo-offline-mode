    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.21.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/socket.io": "^3.0.2",
    "tsx": "^4.11.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
