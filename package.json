{
  "name": "flo-offline-mode",
  "version": "1.0.0",
  "description": "Offline-first autonomy system for field robotics",
  "main": "build/server.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/server.js",
    "dev": "tsx watch src/server.ts",
